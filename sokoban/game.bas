1 REM MSX-BASIC SOKOBAN BY HONUX

20 GOSUB 1000: REM LOAD SPRITES

100 REM INIT
105 COLOR 1,11,14: SCREEN 1
106 REM UP:1 RIGHT:3 DOWN:5 LEFT:7
110 X=128: Y=96: D=3


200 S = STICK(0):B=STRIG(0)
210 IF S = 1 THEN Y=Y-8
220 IF S = 3 THEN X=X+8
230 IF S= 5 THEN Y=Y+8
240 IF S = 7 THEN X=X-8
250 IF B = -1 THEN END
260 GOSUB 300: REM DRAW SPRITES
270 GOTO 200

300 REM DRAW SPRITES

30 GOSUB 100: REM LOAD SPRITES
40 GOSUB 200: REM DRAW SPRITES
90 PRINT "PRESS ANY KEY TO EXIT"
91 A$=INPUT$(1)
92 END

100 REM LOAD SPRITES
105 PRINT "LOADING SPRITES..."
110 FOR I= 0 TO 3
115 FOR J = 0 TO 2
120 S$=""
130 FOR K = 0 TO 7: READ A: S$=S$+CHR$(A): NEXT K
140 SPRITE$(I * 4 + J)=S$
145 PRINT "LOADING SPRITE ";I;J"... OK"
147 NEXT J
150 NEXT I
155 FOR I = 0 TO 3
156 FOR J = 0 TO 2
157 READ A: CL(I, J)=A
158 NEXT J
159 NEXT I
160 PRINT "ALL SPRITES LOADED... OK"
170 RETURN

200 REM DRAW SPRITES
205 CLS
210 X=128: Y=86
220 FOR I= 0 TO 3
230 FOR J = 0 TO 2
240 PUT SPRITE (I * 4 + J), (X,Y + 10 * I), CL(I,J), (I * 4 + J)
250 NEXT J
260 NEXT I
270 RETURN

310 FOR I=0 TO 3
320 PUT SPRITE I, (X,Y), CO(I)
330 NEXT I
340 RETURN

