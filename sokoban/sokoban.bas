1 REM MSX SOKOBAN V2 BY HONUX
2 DEFINT A-Z

100 REM INIT
105 COLOR 1,11,14: SCREEN 2,2,0
110 D=0: P=0
120 GOSUB 1000: REM LOAD SPRITES
130 GOSUB 3000: REM LOAD TILES
140 GOSUB 4000: REM DRAW LEVEL
145 GOSUB 2000: REM DRAW PLAYER

200 REM GAME LOOP
205 A$=INKEY$
210 IF A$="" THEN 205
215 P=D: DX=0: DY=0
220 IF A$=CHR$(28) THEN DX=1: D=0
230 IF A$=CHR$(29) THEN DX=-1: D=1
240 IF A$=CHR$(30) THEN DY=-1: D=2
250 IF A$=CHR$(31) THEN DY=1: D=3
255 IF A$=CHR$(27) THEN END
260 IF DX=0 AND DY=0 THEN 205
265 GOSUB 500: REM TRY MOVE
270 GOSUB 2000: REM DRAW SPRITES
275 GOSUB 5500: REM CHECK WIN
280 GOTO 205

500 REM TRY MOVE
505 NX=PX+DX: NY=PY+DY
510 TX=NX-U: TY=NY-V
515 IF TX<0 OR TY<0 OR TX>=W OR TY>=H THEN RETURN
520 T=MAP(TY,TX)
525 IF T=0 OR T=1 THEN RETURN
530 IF T<>2 AND T<>4 THEN PX=NX: PY=NY: RETURN
535 REM BOX PUSH
540 BX=TX+DX: BY=TY+DY
545 IF BX<0 OR BY<0 OR BX>=W OR BY>=H THEN RETURN
550 BT=MAP(BY,BX)
555 IF BT=0 OR BT=1 OR BT=2 OR BT=4 THEN RETURN
560 IF MAP(TY,TX)=4 THEN MAP(TY,TX)=3 ELSE MAP(TY,TX)=5
565 IF BT=3 THEN MAP(BY,BX)=4 ELSE MAP(BY,BX)=2
570 VPOKE &H1800+U+TX+(TY+V)*32,MAP(TY,TX)
575 VPOKE &H1800+U+BX+(BY+V)*32,MAP(BY,BX)
580 PX=NX: PY=NY
590 RETURN

1000 REM LOAD SPRITES
1010 FOR I=0 TO 11
1020   S$=""
1030   FOR J=0 TO 7: READ A: S$=S$+CHR$(A): NEXT J
1040   SPRITE$(I)=S$
1050 NEXT I
1060 RETURN

2000 REM DRAW SPRITES
2005 IF P<>D THEN GOSUB 2100
2010 PUT SPRITE (D*3),(PX*8-1,PY*8-1),1
2020 PUT SPRITE (D*3+1),(PX*8-1,PY*8-1),6
2030 PUT SPRITE (D*3+2),(PX*8-1,PY*8-1),9
2040 RETURN
2100 REM ERASE OLD DIR SPRITES
2110 PUT SPRITE (P*3),(260,200),1
2120 PUT SPRITE (P*3+1),(260,200),6
2130 PUT SPRITE (P*3+2),(260,200),9
2140 RETURN

3000 REM LOAD TILES
3010 FOR J=0 TO 47
3020   READ R
3030   VPOKE J,R: VPOKE &H800+J,R: VPOKE &H1000+J,R
3040 NEXT J
3050 FOR I=0 TO 5
3060   READ R
3070   FOR J=0 TO 7
3080     VPOKE &H2000+I*8+J,R
3090     VPOKE &H2800+I*8+J,R
3100     VPOKE &H3000+I*8+J,R
3110   NEXT J
3120 NEXT I
3130 RETURN

4000 REM DRAW LEVEL
4005 FOR I=0 TO 767: VPOKE &H1800+I,0: NEXT I
4010 READ W,H
4020 DIM MAP(H,W)
4030 FOR Y=0 TO H-1
4040   FOR X=0 TO W-1
4050     READ R
4055     IF R=6 THEN PX=X: PY=Y: R=5
4060     MAP(Y,X)=R
4070   NEXT X
4080 NEXT Y
4090 U=16-W\2: V=12-H\2
4095 PX=PX+U: PY=PY+V
4100 FOR Y=0 TO H-1
4110   FOR X=0 TO W-1
4120     VPOKE &H1800+U+X+(Y+V)*32,MAP(Y,X)
4130   NEXT X
4140 NEXT Y
4150 RETURN

5000 REM SPRITE DATA - RIGHT
5010 DATA 254,130,171,170,131,124,0,0
5020 DATA 0,124,84,84,124,0,0,0
5030 DATA 0,0,0,0,0,0,231,231
5040 REM - LEFT
5050 DATA 127,65,213,85,193,126,0,0
5060 DATA 0,62,42,42,62,0,0,0
5070 DATA 0,0,0,0,0,0,231,231
5080 REM - UP
5090 DATA 36,255,129,129,129,66,60,0
5100 DATA 0,0,126,126,126,124,0,0
5110 DATA 0,0,0,0,0,0,195,231
5120 REM - DOWN
5130 DATA 0,60,66,129,129,129,255,36
5140 DATA 0,0,124,126,126,126,0,0
5150 DATA 231,195,0,0,0,0,0,0

5200 REM TILE PATTERNS
5205 DATA 0,0,0,0,0,0,0,0
5210 DATA 255,146,255,36,255,73,255,36
5220 DATA 254,130,186,170,186,130,254,0
5225 DATA 36,66,36,219,219,36,66,36
5230 DATA 255,195,189,165,165,189,195,255
5240 DATA 0,170,0,84,0,170,0,84
5250 DATA &H1B,&H1E,&H46,&HF6,&H4B,&H2B

5500 REM CHECK WIN
5505 FOR CY=0 TO H-1
5510   FOR CX=0 TO W-1
5515     IF MAP(CY,CX)=2 THEN RETURN
5520   NEXT CX
5525 NEXT CY
5530 CLS: LOCATE 12,11: PRINT "STAGE CLEAR!!"
5535 A$=INPUT$(1)
5540 END

6000 REM LEVEL 1
6005 DATA 6,5
6010 DATA 1,1,1,1,1,1
6020 DATA 1,5,5,5,5,1
6030 DATA 1,5,2,3,5,1
6040 DATA 1,5,6,5,5,1
6050 DATA 1,1,1,1,1,1
