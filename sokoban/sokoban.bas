1 REM MSX SOKOBAN V2 BY HONUX
2 DEFINT A-Z

100 REM INIT
105 COLOR 1,11,14: SCREEN 2,2,0
110 D=0: P=0: LV=1: MX=5: MV=0
112 DIM MAP(14,14)
120 GOSUB 1000: REM LOAD SPRITES
130 GOSUB 3000: REM LOAD TILES
140 GOSUB 4000: REM DRAW LEVEL
145 GOSUB 2000: REM DRAW PLAYER
147 GOSUB 2200: REM DRAW HUD

200 REM GAME LOOP
205 A$=INKEY$
210 IF A$="" THEN 205
215 P=D: DX=0: DY=0
220 IF A$=CHR$(28) THEN DX=1: D=0
230 IF A$=CHR$(29) THEN DX=-1: D=1
240 IF A$=CHR$(30) THEN DY=-1: D=2
250 IF A$=CHR$(31) THEN DY=1: D=3
255 IF A$=CHR$(27) THEN END
260 IF DX=0 AND DY=0 THEN 205
265 GOSUB 500: REM TRY MOVE
267 IF PX=NX AND PY=NY THEN MV=MV+1: GOSUB 2200
270 GOSUB 2000: REM DRAW SPRITES
275 GOSUB 5500: REM CHECK WIN
280 GOTO 205

500 REM TRY MOVE
505 NX=PX+DX: NY=PY+DY
510 TX=NX-U: TY=NY-V
515 IF TX<0 OR TY<0 OR TX>=W OR TY>=H THEN RETURN
520 T=MAP(TY,TX)
525 IF T=0 OR T=1 THEN RETURN
530 IF T<>2 AND T<>4 THEN PX=NX: PY=NY: RETURN
535 REM BOX PUSH
540 BX=TX+DX: BY=TY+DY
545 IF BX<0 OR BY<0 OR BX>=W OR BY>=H THEN RETURN
550 BT=MAP(BY,BX)
555 IF BT=0 OR BT=1 OR BT=2 OR BT=4 THEN RETURN
560 IF MAP(TY,TX)=4 THEN MAP(TY,TX)=3 ELSE MAP(TY,TX)=5
565 IF BT=3 THEN MAP(BY,BX)=4 ELSE MAP(BY,BX)=2
570 VPOKE &H1800+U+TX+(TY+V)*32,MAP(TY,TX)
575 VPOKE &H1800+U+BX+(BY+V)*32,MAP(BY,BX)
580 PX=NX: PY=NY
590 RETURN

1000 REM LOAD SPRITES
1010 FOR I=0 TO 11
1020   S$=""
1030   FOR J=0 TO 7: READ A: S$=S$+CHR$(A): NEXT J
1040   SPRITE$(I)=S$
1050 NEXT I
1060 RETURN

2000 REM DRAW SPRITES
2005 IF P<>D THEN GOSUB 2100
2010 PUT SPRITE (D*3),(PX*8-1,PY*8-1),1
2020 PUT SPRITE (D*3+1),(PX*8-1,PY*8-1),15
2030 PUT SPRITE (D*3+2),(PX*8-1,PY*8-1),10
2040 RETURN
2100 REM ERASE OLD DIR SPRITES
2110 PUT SPRITE (P*3),(260,200),1
2120 PUT SPRITE (P*3+1),(260,200),15
2130 PUT SPRITE (P*3+2),(260,200),10
2140 RETURN

2200 REM DRAW HUD
2210 LOCATE 0,0: PRINT "STAGE:";LV;"/";MX;"  MOVES:";MV;"    "
2220 RETURN

3000 REM LOAD TILES
3010 FOR J=0 TO 47
3020   READ R
3030   VPOKE J,R: VPOKE &H800+J,R: VPOKE &H1000+J,R
3040 NEXT J
3050 FOR I=0 TO 5
3060   READ R
3070   FOR J=0 TO 7
3080     VPOKE &H2000+I*8+J,R
3090     VPOKE &H2800+I*8+J,R
3100     VPOKE &H3000+I*8+J,R
3110   NEXT J
3120 NEXT I
3123 FOR I=32 TO 127
3124   FOR J=0 TO 7: VPOKE &H2000+I*8+J,&H1B: VPOKE &H2800+I*8+J,&H1B: VPOKE &H3000+I*8+J,&H1B: NEXT J
3125 NEXT I
3130 RETURN

4000 REM DRAW LEVEL
4003 ON LV GOSUB 4160,4161,4162,4163,4164
4004 FOR I=0 TO 14: FOR J=0 TO 14: MAP(I,J)=0: NEXT J: NEXT I
4005 FOR I=0 TO 767: VPOKE &H1800+I,0: NEXT I
4010 READ W,H
4030 FOR Y=0 TO H-1
4040   FOR X=0 TO W-1
4050     READ R
4055     IF R=6 THEN PX=X: PY=Y: R=5
4060     MAP(Y,X)=R
4070   NEXT X
4080 NEXT Y
4090 U=16-W\2: V=12-H\2
4095 PX=PX+U: PY=PY+V
4100 FOR Y=0 TO H-1
4110   FOR X=0 TO W-1
4120     VPOKE &H1800+U+X+(Y+V)*32,MAP(Y,X)
4130   NEXT X
4140 NEXT Y
4150 RETURN
4160 RESTORE 6000: RETURN
4161 RESTORE 6100: RETURN
4162 RESTORE 6200: RETURN
4163 RESTORE 6300: RETURN
4164 RESTORE 6400: RETURN

5000 REM SPRITE DATA - RIGHT
5010 DATA 60,66,66,60,66,37,60,36
5020 DATA 0,60,60,0,60,26,0,0
5030 DATA 0,0,0,0,0,0,0,0
5040 REM - LEFT
5050 DATA 60,66,66,60,66,164,60,36
5060 DATA 0,60,60,0,60,88,0,0
5070 DATA 0,0,0,0,0,0,0,0
5080 REM - UP
5090 DATA 60,126,126,60,66,36,60,36
5100 DATA 0,0,0,0,60,24,0,0
5110 DATA 0,0,0,0,0,0,0,0
5120 REM - DOWN
5130 DATA 60,66,66,60,66,36,60,36
5140 DATA 0,60,60,0,60,24,0,0
5150 DATA 0,0,0,0,0,0,0,0

5200 REM TILE PATTERNS
5205 DATA 0,0,0,0,0,0,0,0
5210 DATA 255,238,255,187,255,238,255,187
5220 DATA 126,129,129,129,129,129,129,126
5225 DATA 60,66,129,153,153,129,66,60
5230 DATA 126,129,129,129,129,129,129,126
5240 DATA 0,0,32,0,0,0,4,0
5250 DATA &H1B,&H98,&H3C,&H74,&HF2,&H1B

5500 REM CHECK WIN
5505 FOR CY=0 TO H-1
5510   FOR CX=0 TO W-1
5515     IF MAP(CY,CX)=2 THEN RETURN
5520   NEXT CX
5525 NEXT CY
5530 LOCATE 0,22: PRINT "  ** STAGE CLEAR!! PRESS KEY **  "
5535 A$=INPUT$(1)
5536 LV=LV+1: IF LV>MX THEN LOCATE 11,11: PRINT "ALL CLEAR!": A$=INPUT$(1): END
5537 MV=0: D=0: P=0
5538 FOR I=0 TO 11: PUT SPRITE I,(260,200),1: NEXT I
5539 GOSUB 4000: GOSUB 2000: GOSUB 2200
5540 RETURN

6000 REM LEVEL 1 - INTRO (1 BOX)
6005 DATA 6,5
6010 DATA 1,1,1,1,1,1
6020 DATA 1,5,5,5,5,1
6030 DATA 1,5,2,3,5,1
6040 DATA 1,5,6,5,5,1
6050 DATA 1,1,1,1,1,1

6100 REM LEVEL 2 - TWO BOXES (7X7)
6105 DATA 7,7
6110 DATA 1,1,1,1,1,1,1
6120 DATA 1,5,5,6,5,5,1
6130 DATA 1,5,2,5,2,5,1
6140 DATA 1,5,5,5,5,5,1
6150 DATA 1,5,3,5,3,5,1
6160 DATA 1,5,5,5,5,5,1
6170 DATA 1,1,1,1,1,1,1

6200 REM LEVEL 3 - ORDER MATTERS (7X6)
6205 DATA 7,6
6210 DATA 1,1,1,1,1,1,1
6220 DATA 1,5,3,3,5,5,1
6230 DATA 1,5,2,5,5,5,1
6240 DATA 1,6,2,5,5,5,1
6250 DATA 1,5,5,5,5,5,1
6260 DATA 1,1,1,1,1,1,1

6300 REM LEVEL 4 - THREE BOXES THROUGH GAPS (9X7)
6305 DATA 9,7
6310 DATA 1,1,1,1,1,1,1,1,1
6320 DATA 1,5,5,5,6,5,5,5,1
6330 DATA 1,5,2,5,2,5,2,5,1
6340 DATA 1,1,5,1,5,1,5,1,1
6350 DATA 1,5,5,5,5,5,5,5,1
6360 DATA 1,5,3,5,3,5,3,5,1
6370 DATA 1,1,1,1,1,1,1,1,1

6400 REM LEVEL 5 - FOUR BOXES SIDE PUSH (9X7)
6405 DATA 9,7
6410 DATA 1,1,1,1,1,1,1,1,1
6420 DATA 1,5,5,5,6,5,5,5,1
6430 DATA 1,5,2,5,2,5,2,5,1
6440 DATA 1,5,5,5,5,5,5,5,1
6450 DATA 1,5,5,2,5,5,5,5,1
6460 DATA 1,5,3,3,3,3,5,5,1
6470 DATA 1,1,1,1,1,1,1,1,1
