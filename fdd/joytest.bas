10 REM JOYSTICK TEST
20 GOSUB 1000: REM LOAD SPRITES

100 REM INIT
105 COLOR 1,11,14: SCREEN 1
110 X=128: Y=96

200 S = STICK(0):B=STRIG(0)
210 IF S = 1 THEN Y=Y-8
220 IF S = 3 THEN X=X+8
230 IF S= 5 THEN Y=Y+8
240 IF S = 7 THEN X=X-8
250 IF B = -1 THEN END
260 GOSUB 300: REM DRAW SPRITES
270 GOTO 200

300 REM DRAW SPRITES
310 FOR I=0 TO 3
320 PUT SPRITE I, (X,Y), CO(I)
330 NEXT I
340 RETURN

1000 REM LOAD SPRITES
1010 DIM BA$(3): DIM CO(3)
1020 FOR I=0 TO 2
1030 BA$=""
1040 FOR J=0 TO 7: READ A: BA$=BA$+CHR$(A): NEXT J
1050 SPRITE$(I)=BA$
1060 READ A: CO(I)=A
1070 NEXT I
1080 RETURN

5000 REM SPRITE DATA PLAYER - RIGHT
5010 DATA 254,130,171,170,131,124,0,0, 1
5020 DATA 0,124,84,84,124,0,0,0, 9
5030 DATA 0,0,0,0,0,0,231,231, 6
