100 REM LOAD SPRITES
110 FOR I= 0 TO 3
120 PL$(I)=""
130 FOR J = 0 TO 7: READ A: PL$(I)=PL$(I)+CHR$(A): NEXT J
140 SP$(I)=PL$(I)
150 NEXT J
160 NEXT I
170 RETURN

200 REM DRAW SPRITES
210 X=128: Y=96
220 FOR I= 0 TO 3
230 PUT SPRITE I, (X + I * 10,Y),1,I
240 NEXT I
250 RETURN


