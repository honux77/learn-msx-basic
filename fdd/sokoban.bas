1 REM MSX-BASIC SOKOBAN BY HONUX

100 REM INIT
105 COLOR 1,11,14: SCREEN 2,2,0
107 DEFINT A-Z
108 REM W: 32, H: 24, SIZE:8
109 REM R:0 L:1 U:2 D:3
110 PX=0: PY=0: D=0: LV=1
120 GOSUB 1000: REM LOAD SPRITES
130 GOSUB 3000: REM LOAD MAP
140 GOSUB 4000: REM DRAW LEVEL

200 REM GAME LOOP
205 S = STICK(0)
210 IF S = 1 THEN  DX=0:DY=-1:GOSUB 400: REM UP
220 IF S = 3 THEN DX=1:DY=0:GOSUB 500: REM RIGHT
230 IF S= 5 THEN DX=0:DY=1:GOSUB 600: REM DOWN
240 IF S = 7 THEN DX=-1:DY=0:GOSUB 700: REM LEFT
250 GOSUB 800: REM UPDATE MAP
260 GOSUB 2000: REM DRAW SPRITES
300 GOTO 200

400 REM MOVE UP
410 IF PY - 1 < 0 THEN RETURN
420 IF MAP(PY -1 , PX) <> 1 THEN PY=PY-1: D=2: RETURN
430 RETURN

500 REM MOVE RIGHT
510 IF PX + 1 > H - 1 THEN RETURN
520 N = MAP(PY , PX + 1)
530 IF N = 4 OR N = 5 THEN PX=PX+1: D=0: RETURN
540 IF PX + 2 > H - 1 THEN RETURN
550 M = MAP(PY , PX + 2)
552 IF N = 2 AND M = 5 THEN MAP(PY , N)=5: MAP(PY , M)=2: PX=PX+1: D=0 RETURN
554 IF N = 2 AND M = 4 THEN MAP(PY , N)=5: MAP(PY , M)=3: PX=PX+1: D=0 RETURN
556 IF N = 3 AND M = 5 THEN MAP(PY , N)=4: MAP(PY , M)=2: PX=PX+1: D=0 RETURN
558 IF N = 3 AND M = 4 THEN MAP(PY , N)=4: MAP(PY , M)=4: PX=PX+1: D=0 RETURN
560 RETURN

600 REM MOVE DOWN
610 IF PY + 1 > V - 1 THEN RETURN
620 IF MAP(PY + 1 , PX) <> 1 THEN PY=PY+1: D=3: RETURN
630 RETURN

700 REM MOVE LEFT
710 IF PX - 1 < 0 THEN RETURN   
720 IF MAP(PY , PX - 1) <> 1 THEN PX=PX-1: D=1: RETURN
730 RETURN

800 REM UPDATE MAP
810 RETURN

1000 REM LOAD SPRITES
1010 FOR I= 0 TO 11
1020 S$=""
1030 FOR J = 0 TO 7: READ A: S$=S$+CHR$(A): NEXT J
1040 SPRITE$(I)=S$
1045 PRINT "LOADING SPRITE ";I;"... OK"
1050 NEXT I
1070 RETURN

2000 REM DRAW SPRITES
2005 DX =(PX + U) * 8: DY = (PY + V) * 8 -1
2007 IF P = D GOTO 2040
2010 PUT SPRITE (P * 3), (260,200), 1
2020 PUT SPRITE (P * 3 + 1), (260,200), 6
2030 PUT SPRITE (P * 3 + 2), (260,200), 9
2040 PUT SPRITE (D * 3), (DX, DY), 1
2050 PUT SPRITE (D * 3 + 1), (DX, DY), 6
2060 PUT SPRITE (D * 3 + 2), (DX, DY), 9
2065 P=D
2070 RETURN

3000 REM LOAD MAP AND COLOR
3010 FOR J=0 TO 47
3020 READ R
3025 PRINT "LOAD MAP PTRN. ";J;" ";R
3030 VPOKE J, R
3040 VPOKE &H800+J, R
3050 VPOKE &H1000+J, R
3060 NEXT J

3100 FOR I=0 TO 5
3110  READ R
3115 PRINT "LOAD MAP COLR. ";I;" ";R
3120  FOR J=0 TO 7
3130   VPOKE &H2000+I*8+J, R
3140   VPOKE &H2800+I*8+J, R
3150   VPOKE &H3000+I*8+J, R
3160  NEXT J
3170 NEXT I
3200 RETURN

4000 REM DRAW LEVEL
4010 READ W, H
4011 PRINT W, H
4020 DIM MAP(H, W)
4030 FOR Y = 0 TO H - 1
4040   FOR X = 0 TO W - 1
4050     READ R
4055     IF R=6 THEN PX=X: PY=Y:R=5
4060     MAP(Y,X)=R
4070   NEXT X
4090 NEXT Y

4100 U = 16 - W / 2
4110 V = 12 - H / 2
4120 FOR Y = 0 TO H - 1
4130   FOR X = 0 TO W - 1
4140     VPOKE &H1800 + U + X + (Y + V)*32, MAP(Y, X)
4150   NEXT X
4160 NEXT Y
4170 RETURN

