1 REM MSX-BASIC SOKOBAN BY HONUX

100 REM INIT
105 COLOR 1,11,14: SCREEN 2,2,0
107 DEFINT A-Z
108 REM W: 32, H: 24, SIZE:8
109 REM R:0 L:1 U:2 D:3
110 X=16: Y=12: D=0: P=0: LV=1
112 DIM CO(3)
114 CO(0)=1: CO(1)=9: CO(2)=6
120 GOSUB 1000: REM LOAD SPRITES
130 GOSUB 3000: REM LOAD MAP

198 X=16: Y=12: D=0: P=0: LV=1
200 REM GAME LOOP
205 S = STICK(0):B=STRIG(0)
208 P=D
210 IF S = 1 THEN Y=Y-1: D=2
220 IF S = 3 THEN X=X+1: D=0
230 IF S= 5 THEN Y=Y+1: D=3
240 IF S = 7 THEN X=X-1: D=1
250 IF B = -1 THEN END
260 GOSUB 2000: REM DRAW SPRITES
270 GOTO 200

1000 REM LOAD SPRITES
1010 FOR I= 0 TO 11
1020 S$=""
1030 FOR J = 0 TO 7: READ A: S$=S$+CHR$(A): NEXT J
1040 SPRITE$(I)=S$
1045 PRINT "LOADING SPRITE ";I;"... OK"
1050 NEXT I
1070 RETURN

2000 REM DRAW SPRITES
2010 IF P <> D THEN GOSUB 2100
2020 FOR I= 0 TO 2
2030 PUT SPRITE (D * 3 + I), (X * 8 - 1,Y * 8 - 1), CO(I)
2040 NEXT I
2050 RETURN
2100 REM ERASE OLD SPRITES
2105 FOR I= 0 TO 2
2110 PUT SPRITE (P * 3 + I), (260,200), CO(I)
2120 NEXT I
2130 RETURN

3000 REM LOAD MAP
3010 FOR J=0 TO 31
3020 READ R
3025 PRINT "LOAD MAP PTRN. ";J;" ";R
3030 VPOKE J, R
3040 VPOKE &H800+J, R
3050 VPOKE &H1000+J, R
3060 NEXT J

3100 FOR I=0 TO 3
3110  READ R
3115 PRINT "LOAD MAP COLR. ";I;" ";R
3120  FOR J=0 TO 7
3130   VPOKE &H2000+I*8+J, R
3140   VPOKE &H2800+I*8+J, R
3150   VPOKE &H3000+I*8+J, R
3160  NEXT J
3170 NEXT I

3200 FOR Y=0 TO 23
3210   FOR X=0 TO 31
3220     VPOKE &H1800 + X + Y*32, RND(1)*4
3230   NEXT X
3240 NEXT Y
3250 RETURN

5000 REM SPRITE DATA PLAYER - RIGHT
5010 DATA 254,130,171,170,131,124,0,0
5020 DATA 0,124,84,84,124,0,0,0
5030 DATA 0,0,0,0,0,0,231,231
5040 REM SPRITE DATA PLAYER - LEFT
5050 DATA 127,65,213,85,193,126,0,0
5060 DATA 0,62,42,42,62,0,0,0
5070 DATA 0,0,0,0,0,0,231,231
5080 REM SPRITE DATA PLAYER - UP
5090 DATA 36,255,129,129,129,66,60,0
5100 DATA 0,0,126,126,126,124,0,0
5110 DATA 0,0,0,0,0,0,195,231
5120 REM SPRITE DATA PLAYER - DOWN
5130 DATA 0,60,66,129,129,129,255,36
5140 DATA 0,0,124,126,126,126,0,0
5150 data 231,195,0,0,0,0,0,0

5200 REM BACKGROUND WALL
5210 DATA 255,146,255,36,255,73,255,36
5220 DATA 255,195,165,153,153,165,195,255
5230 DATA 0,60,66,90,90,66,60,0
5240 data 0,170,0,84,0,170,0,84
5245 REM BACLGRPIMD COLOR DATA
5250 DATA &H1E, &H46, &H4A, &H2A