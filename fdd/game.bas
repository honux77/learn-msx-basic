5100 DATA 0,0,126,126,126,124,0,0
5110 DATA 0,0,0,0,0,0,195,231
5120 REM SPRITE DATA PLAYER - DOWN
5130 DATA 0,60,66,129,129,129,255,36
5140 DATA 0,0,124,126,126,126,0,0
5150 data 231,195,0,0,0,0,0,0

5160 REM SPRITE COLOR DATA
