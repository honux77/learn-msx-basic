1 REM MSX-BASIC SOKOBAN BY HONUX
20 GOSUB 1000: REM LOAD SPRITES

100 REM INIT
105 COLOR 1,11,14: SCREEN 1
107 DEFINT A-Z
108 REM W: 32, H: 24, SIZE:8
109 REM R:0 L:1 U:2 D:3
110 X=16: Y=12: D=0: P=0: LV=1
112 DIM CO(3)
114 CO(0)=1: CO(1)=9: CO(2)=6

200 REM GAME LOOP
205 S = STICK(0):B=STRIG(0)
208 P=D
210 IF S = 1 THEN Y=Y-1: D=2
220 IF S = 3 THEN X=X+1: D=0
230 IF S= 5 THEN Y=Y+1: D=3
240 IF S = 7 THEN X=X-1: D=1
250 IF B = -1 THEN END
260 GOSUB 2000: REM DRAW SPRITES
270 GOTO 200

1000 REM LOAD SPRITES
1005 PRINT "LOADING SPRITES..."
1010 FOR I= 0 TO 11
1020 S$=""
1030 FOR J = 0 TO 7: READ A: S$=S$+CHR$(A): NEXT J
1040 SPRITE$(I)=S$
1045 PRINT "LOADING SPRITE ";I;"... OK"
1050 NEXT I
1060 PRINT "ALL SPRITES LOADED... OK"
1065 CLS: SCREEN 2
1070 RETURN

2000 REM DRAW SPRITES
2010 IF P <> D THEN GOSUB 2100
2020 FOR I= 0 TO 2
2030 PUT SPRITE (D * 3 + I), (X * 8,Y * 8), CO(I)
2040 NEXT I
2050 RETURN
2100 REM ERASE OLD SPRITES
2105 FOR I= 0 TO 2
2110 PUT SPRITE (P * 3 + I), (260,200), CO(I)
2120 NEXT I
2130 RETURN

5000 REM SPRITE DATA PLAYER - RIGHT
5010 DATA 254,130,171,170,131,124,0,0
